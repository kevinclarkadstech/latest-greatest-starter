API_KEY=abc123

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# AWS S3
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Better Auth
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated list of origins allowed to call Better Auth endpoints (used by toNodeHandler CORS)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# CORS for Fastify routes (tRPC, etc.) — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173