{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Strictness - Essential for tRPC safety */
    "strict": true,
    "noUncheckedIndexedAccess": true, // Forces you to check if an array item exists
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    /* Emission */
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "removeComments": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@infra/*": ["./src/infra/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
