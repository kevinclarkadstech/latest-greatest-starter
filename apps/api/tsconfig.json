{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Strictness - Essential for tRPC safety */
    "strict": true,
    "noUncheckedIndexedAccess": true, // Forces you to check if an array item exists
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    /* Emission */
    "outDir": "dist",
    "sourceMap": true,
    "removeComments": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Path Aliases (Optional but highly recommended) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
